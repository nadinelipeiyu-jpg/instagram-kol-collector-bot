# ── Telegram ──────────────────────────────────────────────────────────────────
TG_TOKEN=your-telegram-bot-token

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=your-apify-token
APIFY_PROFILE_ACTOR_ID=dSCLg0C3YEZ83HzYX
APIFY_REEL_ACTOR_ID=apify~instagram-reel-scraper

# ── Google Sheets ─────────────────────────────────────────────────────────────
SHEET_NAME=KOL_Master
WORKSHEET_NAME=Creator_Master

# ── Google 認證（兩種方式擇一）────────────────────────────────────────────────
# 本機：指定 service account JSON 檔案路徑
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# 雲端部署（Cloud Run / Docker）：貼入 JSON 內容，不需要實體檔案
# GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account","project_id":"..."}

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-public-bucket-name
GCS_AVATAR_PREFIX=avatars

# ── Polling 模式（本機）──────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=5
OFFSET_FILE=.telegram_offset

# ── Webhook / Cloud Run 模式 ──────────────────────────────────────────────────
# Cloud Run 自動注入 PORT；本機測試可手動設定
# PORT=8080

# 部署後取得 Cloud Run 服務 URL 填入此處，Bot 才能收到 Telegram 訊息
# WEBHOOK_URL=https://kol-bot-xxxx-de.a.run.app
